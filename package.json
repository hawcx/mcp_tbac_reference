{
  "name": "hx-mcp-tbac",
  "private": true,
  "version": "0.0.0",
  "description": "Clean-room reference implementation of MCP TBAC (SEP r40).",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "demo": "pnpm --filter hawcx-mcp-auth run demo",
    "demo:widening": "pnpm --filter hawcx-mcp-auth run demo:widening",
    "vectors:regen": "pnpm --filter @hawcx/tbac-core run vectors:generate",
    "guard:no-haap": "bash scripts/no-haap-prefix.sh"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
